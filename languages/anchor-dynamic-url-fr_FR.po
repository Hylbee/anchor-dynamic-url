#. translators: %s: Required PHP version
#: anchor-dynamic-url.php:35
msgid "Anchor Dynamic URL requires PHP version %s or higher."
msgstr "Anchor Dynamic URL nécessite PHP version %s ou supérieur."

#. translators: %s: Required WordPress version
#: anchor-dynamic-url.php:51
msgid "Anchor Dynamic URL requires WordPress version %s or higher."
msgstr "Anchor Dynamic URL nécessite WordPress version %s ou supérieur."

#. translators: Error message shown when WordPress version is too old (wp_die title)
#: anchor-dynamic-url.php:124
msgid "Anchor Dynamic URL requires WordPress 5.0 or higher."
msgstr "Anchor Dynamic URL nécessite WordPress 5.0 ou supérieur."

#. translators: Title of the wp_die error page on activation failure
#: anchor-dynamic-url.php:125
#: anchor-dynamic-url.php:135
msgid "Plugin Activation Error"
msgstr "Erreur d'activation du plugin"

#. translators: Error message shown when PHP version is too old (wp_die title)
#: anchor-dynamic-url.php:134
msgid "Anchor Dynamic URL requires PHP 7.4 or higher."
msgstr "Anchor Dynamic URL nécessite PHP 7.4 ou supérieur."

#. translators: Error message when changelog cannot be fetched from GitHub
#: includes/class-anchor-updater.php:247
msgid "Unable to fetch changelog."
msgstr "Impossible de récupérer le journal des modifications."

#. translators: Message shown when no changelog data is available
#: includes/class-anchor-updater.php:255
msgid "No changelog available."
msgstr "Aucun journal des modifications disponible."

#. translators: Message shown when a release has no notes
#: includes/class-anchor-updater.php:264
msgid "No release notes available."
msgstr "Aucune note de version disponible."

#. translators: 1: version number, 2: release date
#: includes/class-anchor-updater.php:268
msgid "Version %1$s - %2$s"
msgstr "Version %1$s - %2$s"

#. translators: 1: version number, 2: update URL
#: includes/class-anchor-updater.php:297
msgid "Anchor Dynamic URL version %1$s is available. <a href=\"%2$s\">Update now</a>."
msgstr "Anchor Dynamic URL version %1$s est disponible. <a href=\"%2$s\">Mettre à jour maintenant</a>."

#. translators: Link text for viewing the plugin changelog
#: includes/class-anchor-manager.php:158
msgid "View Changelog"
msgstr "Voir le journal des modifications"

#. translators: Link text for getting support
#: includes/class-anchor-manager.php:161
msgid "Support"
msgstr "Support"

#. translators: Link text for GitHub repository
#: includes/class-anchor-manager.php:164
msgid "GitHub"
msgstr "GitHub"

#. translators: Link text for configuring menus
#: includes/class-anchor-manager.php:184
msgid "Configure Menus"
msgstr "Configurer les menus"

#. translators: Label for the anchor input field in menu editor
#: includes/class-anchor-service.php:82
msgid "Anchor (optional)"
msgstr "Ancre (optionnel)"

#. translators: Example placeholder text for anchor input field
#: includes/class-anchor-service.php:92
msgid "e.g: contact-section"
msgstr "ex : section-contact"

#. translators: Help text explaining what the anchor field does
#: includes/class-anchor-service.php:99
msgid "Adds #anchor to the URL. Updates automatically if the page slug changes."
msgstr "Ajoute #ancre à l'URL. Se met à jour automatiquement si le slug de la page change."

#. translators: Label for the anchor target input field in Elementor
#: includes/elementor-integration.php:107
msgid "Target Anchor"
msgstr "Ancre cible"

#. translators: Placeholder text for anchor target input in Elementor
#: includes/elementor-integration.php:108
msgid "section-id"
msgstr "id-section"

#. translators: Help text explaining how to use the anchor target field in Elementor
#: includes/elementor-integration.php:110
msgid "ID of the target element for scrolling (without #). Leave blank to use the normal link."
msgstr "ID de l'élément cible pour le défilement (sans #). Laissez vide pour utiliser le lien normal."
